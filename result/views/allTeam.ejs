<!DOCTYPE html>
<html>
    <head>
        <style>
            :root {
                --w: 0;
                --h: 0;
                --pageFontSize: 15px;
            }

            body {
                width: 100vw;
                height: 100vh;
                margin: 0;
                padding: 0;
                border: 0;
                background-color: var(--logoBlue);
            }

            #body-div {
                width: var(--w);
                height: var(--h);
                overflow: hidden;
            }

            main {
                width: 100%;
                height: 85%;
            }
            #m-table-div {
                position: relative;
                top: 10%;
                height: 80%;
                width: 100%;
            }
        </style>
    </head>
    <body>
        <div id="body-div">
            <header id="header">
                <%- include('../template/header') %>
            </header>
            
            <main>
                <div id="m-table-div">
                    <%- include('../template/AllTeamTable') %>
                </div>
            </main>    
        </div>

        <script src="./setSize.js" type="text/javascript"></script>
    </body>
</html>