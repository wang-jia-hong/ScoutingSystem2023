<!DOCTYPE html>
<html>
    <head>
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Proza+Libre&display=swap" rel="stylesheet">
        <style>
            :root {
                --logoBlue: #002a5c;
            }

            body {
                width: 100vw;
                height: 100vh;
                background-color: var(--logoBlue);
                padding: 0;
                margin: 0;
            }

            #main-div {
                width: 100%;
                height: 60%;
                position: fixed;
                top: 5vh;
            }

            #logo-div {
                width: 25%;
                aspect-ratio: 1 / 1;
                position: absolute;
                left: 10%;
                bottom: 0;
                display: flex;
                justify-content: center;
                overflow: hidden;
            }

            #logo {
                width: 100%;
            }

            #title-div {
                width: 50%;
                height: 25%;
                position: absolute;
                right: 10%;
                bottom: 5%;
                display: flex;
                align-items: center;
            }

            #title {
                color: #ffffff;
                font-size: 70px;
                font-family: 'Proza Libre', serif;
            }
        </style>
    </head>
    <body>
        <div id="main-div">
            <div id="logo-div">
                <img src="./7636Logo.png" id="logo">
            </div>
    
            <div id="title-div">
                <h1 id="title">Check the result scouted by us</h1>
            </div>
        </div>
    </body>
</html>